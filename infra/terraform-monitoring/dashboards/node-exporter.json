{
    "uid": "node-exporter-simple",
    "title": "Node Exporter - System Overview",
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",

    "time": {
        "from": "now-6h",
        "to": "now"
    },

    "panels": [
        {
            "id": 1,
            "type": "timeseries",
            "title": "CPU Usage (%)",
            "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
            "targets": [
                {
                    "refId": "A",
                    "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)"
                }
            ]
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "Memory Usage (%)",
            "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
            "targets": [
                {
                    "refId": "B",
                    "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100"
                }
            ]
        },
        {
            "id": 3,
            "type": "timeseries",
            "title": "Disk Usage (%)",
            "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
            "targets": [
                {
                    "refId": "C",
                    "expr": "100 - ((node_filesystem_avail_bytes{fstype!=\"tmpfs\",fstype!=\"overlay\"} / node_filesystem_size_bytes) * 100)"
                }
            ]
        },
        {
            "id": 4,
            "type": "timeseries",
            "title": "Network Receive (bytes/sec)",
            "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
            "targets": [
                {
                    "refId": "D",
                    "expr": "rate(node_network_receive_bytes_total[5m])"
                }
            ]
        },
        {
            "id": 5,
            "type": "timeseries",
            "title": "Network Transmit (bytes/sec)",
            "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
            "targets": [
                {
                    "refId": "E",
                    "expr": "rate(node_network_transmit_bytes_total[5m])"
                }
            ]
        }
    ]
}
